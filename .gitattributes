# Handle line endings automatically for files detected as text
* text=auto

# Force LF for these file types
*.kt text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.pro text eol=lf

# Shell scripts must use LF
*.sh text eol=lf
gradlew text eol=lf

# Windows scripts must use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.bin binary
*.dex binary
*.apk binary
*.aar binary
*.so binary
*.jar binary
*.zip binary
*.tar.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
